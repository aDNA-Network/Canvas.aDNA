      "height": 560,
      "label": "Page 1"
    },
    {
      "id": "body",
      "type": "text",
      "x": 0,
      "y": 0,
      "width": 280,
      "height": 100,
      "text": "Mondrian reduced composition to a grid of straight lines and primary fields."
    },
    {
      "id": "pq",
      "type": "text",
      "x": 0,
      "y": 120,
      "width": 280,
      "height": 80,
      "text": "The grid is not a cage but a grammar."
    },
    {
      "id": "bq",
      "type": "text",
      "x": 0,
      "y": 220,
      "width": 280,
      "height": 100,
      "text": "We must reduce to the fewest elements that still express the whole."
    },
    {
      "id": "attr",
      "type": "text",
      "x": 0,
      "y": 340,
      "width": 280,
      "height": 40,
      "text": "— De Stijl, 1917"
    },
    {
      "id": "fn1",
      "type": "text",
      "x": 0,
      "y": 400,
      "width": 280,
      "height": 60,
      "text": "1. On reduction as a universal visual language."
    }
  ],
