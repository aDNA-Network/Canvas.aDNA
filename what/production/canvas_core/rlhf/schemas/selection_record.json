{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SelectionRecord",
  "description": "Canonical schema for canvas-RLHF variant-selection decisions. Per skill_canvas_variant_selection.md § 5.",
  "type": "object",
  "required": ["selection_id", "timestamp", "prompt", "register", "variants", "pick_index", "pick_reason", "approver_id"],
  "properties": {
    "selection_id": {
      "type": "string",
      "pattern": "^sel_\\d{8}_\\d{6}_[0-9a-f]{4}$",
      "description": "Globally unique ID: sel_YYYYMMDD_HHMMSS_<4-hex>"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 UTC timestamp"
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "description": "Original text prompt that generated the variants"
    },
    "register": {
      "type": "string",
      "minLength": 1,
      "description": "Voice register (R1-R12)"
    },
    "budget_class": {
      "type": "string",
      "enum": ["economy", "standard", "premium"],
      "default": "standard"
    },
    "variants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["image_path", "model", "cost_usd"],
        "properties": {
          "image_path": { "type": "string" },
          "model": { "type": "string" },
          "cost_usd": { "type": "number", "minimum": 0 },
          "seed": { "type": ["integer", "null"] }
        }
      }
    },
    "pick_index": {
      "type": "integer",
      "minimum": 0,
      "description": "0-indexed position of the selected variant"
    },
    "pick_reason": {
      "type": "string",
      "minLength": 1,
      "description": "Human explanation for the selection"
    },
    "approver_id": {
      "type": "string",
      "minLength": 1,
      "description": "Human reviewer identifier"
    },
    "register_compliance_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 1
    },
    "vr_scores": {
      "type": ["object", "null"],
      "description": "VR1-VR5 scores if available"
    }
  }
}
